rules_version = '2';
// Masaremaar CMS — Firebase Storage Security Rules
//
// DEPLOY: firebase deploy --only storage
// Or paste directly into Firebase Console → Storage → Rules tab.
//
// Admin access requires custom claim (admin: true). Set via:
//   node --env-file=.env.local scripts/set-admin-claim.mjs <uid>

service firebase.storage {
  match /b/{bucket}/o {

    // Helper — true when the caller is authenticated and has the admin claim.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.admin == true;
    }

    // ── Public project images ─────────────────────────────────────────────────
    // Stored under projects/<projectId>/<filename>.
    // Public browsers may read (so next/image can proxy them via Vercel).
    // Only admins may upload, overwrite, or delete.
    // Uploads are restricted to images ≤ 5 MB.
    match /projects/{projectId}/{filename} {
      allow read: if true;

      allow write: if isAdmin()
          && request.resource.size <= 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');

      allow delete: if isAdmin();
    }

    // ── Default — deny everything else ───────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
